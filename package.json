{
  "name": "governed-prompt-studio",
  "displayName": "Governed Prompt Studio",
  "description": "Governed prompt studio for GitHub Copilot without direct API integration.",
  "version": "0.1.0",
  "publisher": "donaldomoreno",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiGovernance.openPromptStudio",
    "onCommand:aiGovernance.copyGovernedPrompt",
    "onCommand:aiGovernance.runPolicyCheck",
    "onCommand:aiGovernance.setTier",
    "onCommand:aiGovernance.initSession",
    "onCommand:aiGovernance.setTaskMode",
    "onCommand:aiGovernance.scaffoldCopilotInstructions"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "contributes": {
    "commands": [
      {
        "command": "aiGovernance.openPromptStudio",
        "title": "AI Governance: Open Prompt Studio"
      },
      {
        "command": "aiGovernance.copyGovernedPrompt",
        "title": "AI Governance: Copy Governed Prompt to Clipboard"
      },
      {
        "command": "aiGovernance.runPolicyCheck",
        "title": "AI Governance: Run Policy Check"
      },
      {
        "command": "aiGovernance.setTier",
        "title": "AI Governance: Set Tier"
      },
      {
        "command": "aiGovernance.initSession",
        "title": "AI Governance: Inicializar sesión gobernada"
      },
      {
        "command": "aiGovernance.setTaskMode",
        "title": "AI Governance: Establecer modo de tarea"
      },
      {
        "command": "aiGovernance.scaffoldCopilotInstructions",
        "title": "AI Governance: Crear instrucciones para Copilot"
      }
    ],
    "configuration": {
      "title": "AI Governance",
      "properties": {
        "aiGovernance.tier": {
          "type": "string",
          "enum": [
            "auto",
            "1",
            "2",
            "3"
          ],
          "default": "auto",
          "description": "Project governance tier. Use auto for automatic detection."
        },
        "aiGovernance.preset": {
          "type": "string",
          "enum": [
            "Fast",
            "Safe",
            "Strict"
          ],
          "default": "Safe",
          "description": "Governance preset applied when compiling prompts."
        },
        "aiGovernance.taskMode": {
          "type": "string",
          "enum": [
            "auto",
            "design-system",
            "debugging",
            "new-feature"
          ],
          "default": "auto",
          "description": "Modo de tarea activo para la generación de prompts."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DonaldoMoreno/AI-Governance.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/DonaldoMoreno/AI-Governance/issues"
  },
  "homepage": "https://github.com/DonaldoMoreno/AI-Governance#readme",
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.9.3",
    "vsce": "^2.15.0"
  }
}
